Buffs: {
	BetelNutAddictionBuff: {
		DisplayName: Betel Nut Addiction
		DisplayNameWithCount: "{0} ({1})"
		Description: You feel an aching emptiness... You need to chew on something to ease it.
	}

	BetelWithdrawal: {
		Level1: {
			DisplayName: Munchies
			Description: Your mouth feels empty, and even your steps feel hollow. Movement speed slightly reduced.
		}

		Level2: {
			DisplayName: Craving
			Description: Your mouth waters uncontrollably, and your swings feel weaker. Movement speed and damage slightly reduced.
		}

		Level3: {
			DisplayName: Restless
			Description: The screen begins to warp. Your hands shake. Damage and movement speed reduced.
		}

		Level4: {
			DisplayName: Withdrawal
			Description: Your head feels heavy and your vision blurs. Life regen stops and stats drop sharply.
		}

		Level5: {
			DisplayName: Severe Withdrawal
			Description: Your heartbeat thunders, your vision warps and greys out, and you bleed continuously. Chew something, NOW!
		}
	}

	ChewSatisfaction: {
		Level1: {
			DisplayName: Chew Satisfaction! (Level 1)
			Description: The high kicks in! Wind underfoot lets you glide, and you can see in the dark. Mouth moves, legs float.
		}

		Level2: {
			DisplayName: Chew Satisfaction! (Level 2)
			Description: The high deepens and a "treasure eye" opens; underground ores and chests glow and wave at you.
		}

		Level3: {
			DisplayName: Chew Satisfaction! (Level 3)
			Description: Legs on autopilot! Double-tap a direction to dash, on top of glide and treasure sight.
		}

		Level4: {
			DisplayName: Chew Satisfaction! (Level 4)
			Description: High enough to double jump, kicking off mid-air; danger sense reveals every trap.
		}

		Level5: {
			DisplayName: Chew Satisfaction! (Level 5)
			Description: Golden-mouth blessing: the screen points toward nearby treasure, and drops magnetize from across the screen.
		}

		Level6: {
			DisplayName: Chew Satisfaction! (Level 6)
			Description: Ascension — hold jump to fly; treasure, danger and creature sight all maxed out.
		}
	}
}

Items: {
	BigFruit: {
		DisplayName: Big Fruit
		Tooltip: A big fruit fallen from the tree, rock hard to the touch.
	}

	BigFruitCutterbar: {
		DisplayName: Big Fruit Cutterbar
		Tooltip:
			'''
			Looking at this thing makes your mouth water.
			Place it to slice big fruits into peeled big fruits, or pack chewable big fruits into daily packs.
			'''
	}

	BigFruitCutterbarMk2: {
		DisplayName: Big Fruit Cutterbar Mk2
		Tooltip:
			'''
			An upgraded cutterbar that emanates a strong metallic aura.
			Retains slicing functionality and packs chewable big fruits into premium gift boxes (hardmode).
			'''
	}

	BigFruitleaf: {
		DisplayName: Big Fruitleaf
		Tooltip: A big fruit leaf fallen from the tree, rough to the touch.
	}

	HailanBigFruit: {
		DisplayName: Hainan Original Big Fruit
		Tooltip:
			'''
			A bitter, unripe big fruit with a strange taste that is hard to endure.
			The easiest big fruit recipe for the early game.
			'''
	}

	BetelTreat: {
		DisplayName: A Round of Big Fruit
		Tooltip:
			'''
			Use it near a town NPC to offer them a big fruit.
			They get high for a minute: shop discounts, plus they start talking nonsense.
			'''
	}

