Common: {
	AddictionGain: +{0} Addiction
	PlaceboChew: Chewed absolutely nothing
	StuckTeeth: Chipped a tooth! This fruit is absurdly hard
	CutterNoFruit: Cutterbar: where fruit?
	CutterResult: Sliced out: {0}
	CutterResultMythic: Mythic pull! {0}. Your mouth is chewing by itself

	WithdrawalNag: {
		Level1: Your mouth has no job
		Level2: The drool clocked in
	}

	Blessing: {
		Wealth: {
			Line1: Fortune comes! One chew and the money rolls in
			Line2: The wealth god possesses you, coins grow legs
			Line3: The more you chew, the richer you get
		}

		Guard: {
			Line1: Wards off evil, even monsters keep their distance
			Line2: Golden bell shield on, steady as an old dog
			Line3: Chewed up an iron shirt, blades feel meh now
		}

		Enlighten: {
			Line1: Blessed and enlightened, clearer with every chew
			Line2: Zen big-fruit chewing, heals and soothes
			Line3: Golden body on, the pain drifts away
		}
	}

	Hallucination: {
		Line1: The big fruit is calling me...
		Line2: Did you hear it? The drool is singing
		Line3: The wall is chewing something
		Line4: One more chew and the craving stops, for real
		Line5: A fruit just drifted by over there...
	}

	PhantomChew: Phantom chew... feels a little better? maybe?

	Unlock: {
		Glide: Wind underfoot! Hold jump to glide
		Spelunk: Treasure eye! Ores and chests start glowing
		Dash: Legs on autopilot! Double-tap to dash
		DoubleJump: Double jump! Kick off the air again
		Compass: Treasure instinct! The screen edge points to loot
		Fly: Ascension! Hold jump to take off
	}

	FeedSuccess: "{0} is chewing now! Much easier to deal with"

	NPCHigh: {
		Line1: This fruit... what a high!
		Line2: Everything's on a fat discount today, take your pick
		Line3: One more bite and anything's negotiable
	}
}

