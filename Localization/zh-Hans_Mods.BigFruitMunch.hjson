Buffs: {
	BetelNutAddictionBuff: {
		DisplayName: 大果成瘾
		DisplayNameWithCount: "{0}（{1}）"
		Description: 你感觉到一阵空虚……必须要嚼点什么来缓解。
	}

	BetelWithdrawal: {
		Level1: {
			DisplayName: 嘴馋
			Description: 嘴里淡出鸟来，脚步都虚了点。移动速度轻微下降。
		}

		Level2: {
			DisplayName: 渴求
			Description: 嘴里发酸、口水不停，连出手都没那么有劲。移动速度与伤害略微下降。
		}

		Level3: {
			DisplayName: 焦躁
			Description: 屏幕开始扭曲，心慌、手颤，伤害与移动速度下降。
		}

		Level4: {
			DisplayName: 戒断
			Description: 头重脚轻、眼前发花，生命无法回复且属性大幅下降。
		}

		Level5: {
			DisplayName: 极度戒断
			Description: 心跳轰鸣，视野扭曲变灰，持续掉血并失去战斗力。再不嚼点东西就完了！
		}
	}

	ChewSatisfaction: {
		Level1: {
			DisplayName: 嚼的爽！(1级)
			Description: 上头了！脚下生风可滑翔缓降，夜里也看得清。嘴一动，腿也飘。
		}

		Level2: {
			DisplayName: 嚼的爽！(2级)
			Description: 上头加深，睁开“探宝之眼”，地下矿石与宝藏自己发光招手。
		}

		Level3: {
			DisplayName: 嚼的爽！(3级)
			Description: 腿不是自己的了！双击方向就能灵动冲刺，外加滑翔与透视。
		}

		Level4: {
			DisplayName: 嚼的爽！(4级)
			Description: 上头到能二段跳，空中再蹬一脚；还多了危险感知，陷阱无所遁形。
		}

		Level5: {
			DisplayName: 嚼的爽！(5级)
			Description: 金口玉牙开光：屏幕指出附近宝藏方向，掉落物全屏磁吸进兜。
		}

		Level6: {
			DisplayName: 嚼的爽！(6级)
			Description: 羽化登仙，按住跳直接起飞；探宝、危险、生物全套透视拉满。
		}
	}
}

Items: {
	BigFruit: {
		DisplayName: 大果
		Tooltip: 从树上掉下来的大果，拿在手上梆硬
	}

	BigFruitCutterbar: {
		DisplayName: 大果切割机
		Tooltip:
			'''
			看着这个东西，你感觉到口水直流。
			放置后可将大果切为去皮大果，也可将可嚼大果打包为日常装大果。
			'''
	}

	BigFruitCutterbarMk2: {
		DisplayName: 大果切割机Mk2
		Tooltip:
			'''
			升级版的大果切割机，散发着一股强烈的金属气息。
			兼容切果功能，并可将可嚼大果打包为礼盒装精品大果（肉后）。
			'''
	}

	BigFruitleaf: {
		DisplayName: 大果叶
		Tooltip: 从树上掉下来的大果叶，摸着很粗糙
	}

	HailanBigFruit: {
		DisplayName: 海南原味大果
		Tooltip: 青涩的苦味大果，有一种人难以忍受的奇怪口感
	}

	BetelTreat: {
		DisplayName: 敬一口大果
		Tooltip:
			'''
			对着附近的镇民使用，敬他一口大果。
			镇民会上头一分钟：商店打折，还会开始说胡话。
			'''
	}

