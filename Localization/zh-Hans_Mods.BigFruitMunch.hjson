Common: {
	AddictionGain: +{0} 成瘾
	PlaceboChew: 嚼了个寂寞
	StuckTeeth: 硌牙了！这果硬得离谱
	CutterNoFruit: 切割机：果呢？
	CutterResult: 切出了：{0}
	CutterResultMythic: 神话出货！{0}，嘴已经开始自己嚼了

	WithdrawalNag: {
		Level1: 嘴里没活了
		Level2: 口水开始自己上班
	}

	Blessing: {
		Wealth: {
			Line1: 招财进宝，嘴一动财源滚滚
			Line2: 财神附体，钱自己长腿来找你
			Line3: 越嚼越有，金光护体
		}

		Guard: {
			Line1: 镇宅辟邪，怪都不敢碰你
			Line2: 金钟罩护体，稳如老狗
			Line3: 嚼出铁布衫，刀枪也就那样
		}

		Enlighten: {
			Line1: 开光加持，越嚼越通透
			Line2: 佛系嚼大果，回血又顺气
			Line3: 金身护体，伤痛随风去
		}
	}

	Hallucination: {
		Line1: 大果在叫我……
		Line2: 你听见了吗，口水在唱歌
		Line3: 墙在嚼东西
		Line4: 再嚼一口就不馋了，真的
		Line5: 那边……飘过去一颗果
	}

	PhantomChew: 幻象嚼食……好像，舒服了一点？

	Unlock: {
		Glide: 脚下生风！按住跳可滑翔缓降
		Spelunk: 探宝之眼！矿石宝藏开始发光
		Dash: 腿不是自己的！双击方向灵动冲刺
		DoubleJump: 二段跳！空中再蹬一脚
		Compass: 寻宝直觉！屏幕边缘指出宝藏方向
		Fly: 羽化登仙！按住跳直接起飞
	}

	FeedSuccess: "{0} 嚼上头了！这波好商量"

	NPCHigh: {
		Line1: 这果……上头啊！
		Line2: 老板今天打骨折，随便挑
		Line3: 再来一口，啥都好说
	}
}

